# Copier vers .env et adapter (ne pas committer les secrets)

# --- Ollama / Jarvis ---
OLLAMA_HOST=http://127.0.0.1:11434
# 0 = CPU stable sur GTX 1650 4 Go | vide = auto Ollama
OLLAMA_NUM_GPU=0
OLLAMA_KEEP_ALIVE=30m
# Variable systeme Ollama (PowerShell) : $env:OLLAMA_MAX_LOADED_MODELS="1"

JARVIS_MODEL=qwen2.5:1.5b-instruct-q4_K_M
JARVIS_FAST_MODEL=qwen2.5:1.5b-instruct-q4_K_M
JARVIS_QUALITY_MODEL=qwen2.5:3b-instruct-q4_K_M
JARVIS_WAKE_MODEL=qwen2.5:0.5b
JARVIS_QUALITY_MIN_CHARS=200

JARVIS_NUM_CTX=1536
JARVIS_MAX_TOKENS=512
JARVIS_MEMORY_TURNS=4
JARVIS_MEMORY_MAX_CHARS=2000
JARVIS_MEMORY_SUMMARY_EVERY=15
JARVIS_MEMORY_SUMMARY_WINDOW=15
JARVIS_EMBED_MODEL=nomic-embed-text
JARVIS_CHROMA_PATH=data/chroma

# Profil personnel (memoire — ton pote, pas froid)
JARVIS_USER_NAME=Briac
JARVIS_USER_ROLE=ton pote
# JARVIS_USER_AVOID=Raphaël
JARVIS_SEED_PERSONAL_FACT=true
# JARVIS_PERSONAL_FACT=Je m'appelle Briac, tutoie-moi...

# --- Cloud Groq (fallback / raisonnement) ---
CLOUD_ENABLED=false
CLOUD_BASE_URL=https://api.groq.com/openai/v1
CLOUD_API_KEY=
# ou alias Groq officiel (une seule des deux lignes) :
# GROQ_API_KEY=gsk_...
CLOUD_MODEL=llama-3.1-8b-instant
CLOUD_MODEL_HEAVY=deepseek-r1-distill-llama-70b
CLOUD_MAX_TOKENS=768
CLOUD_DAILY_LIMIT=30
CLOUD_COMPLEXITY_THRESHOLD=5
CLOUD_HEAVY_THRESHOLD=8
ROUTER_PEDAGOGICAL_CLOUD_SCORE=4
FALLBACK_MIN_ANSWER_CHARS=80
FALLBACK_MIN_RATIO=0.15

# TTS : lire toute la reponse (decoupee en morceaux de ~450 car.)
# JARVIS_TTS_SPEAK_MAX=12000
# JARVIS_TTS_CHUNK_CHARS=450
# JARVIS_WEB_TIMEOUT=6
# JARVIS_PRE_LLM_PARALLEL=true
# JARVIS_ROUTE_RACE=false
# JARVIS_TIMEOUT=90
# JARVIS_STREAM_TIMEOUT=120
# JARVIS_USER_NAME=Briac
# JARVIS_USER_ROLE=ton pote

# --- Tidal (optionnel) ---
TIDAL_CLIENT_ID=
TIDAL_CLIENT_SECRET=
TIDAL_COUNTRY_CODE=FR
TIDAL_ENABLED=true
TIDAL_REDIRECT_URI=http://127.0.0.1:8000/tidal/callback
TIDAL_CDP_ENABLED=true
TIDAL_CDP_PORT=9222
TIDAL_CDP_RELAUNCH=true
